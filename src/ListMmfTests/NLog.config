<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Warn" internalLogFile="c:\logs\nlog-internal.log">

  <variable name="appName" value="BruTrader20"/>
  <targets>

    <default-wrapper xsi:type="AsyncWrapper" timeToSleepBetweenBatches="0" overflowAction="Block" />

    <!--Must have type Network to drag from the exe.config, then change to NLogViewer-->
    <!--<target name="log4viewCharts" xsi:type="NLogViewer"
            address="udp://127.0.0.1:877"
            newLine="false" maxMessageSize="65000" encoding="utf-8"
            layout="${log4jxmlevent:includeCallSite=true:includeNLogData=true}"
            includeSourceInfo="true"
            includeCallSite="true"
            IncludeAllProperties="true"
            />-->
    
    
     <target name="log4viewDev" xsi:type="NLogViewer" address="udp://127.0.0.1:900" newLine="false" maxMessageSize="65000" encoding="utf-8"  
             layout="${log4jxmlevent:includeCallSite=true:includeNLogData=true}" includeSourceInfo="true" includeCallSite="true" IncludeAllProperties="true"/> 
    <target name="log4viewTrading" xsi:type="NLogViewer" address="udp://127.0.0.1:899" newLine="false" maxMessageSize="65000" encoding="utf-8"
            layout="${log4jxmlevent:includeCallSite=true:includeNLogData=true}" includeSourceInfo="true" includeCallSite="true" IncludeAllProperties="true"/>
    <!-- <target xsi:type="File" name="fileViewer"  -->
    <!--         layout="${longdate}|${level:uppercase=true}|${message}|${threadid}|${callsite:className=true:includeNamespace=true:fileName=true:includeSourcePath=false:methodName=true}|${exception}" -->
    <!--          -->
    <!--         fileName="C:\GitDev\BruTrader20\src\logs\BruTrader20.log" keepFileOpen="True" concurrentwrites="True" openFileCacheTimeout="30"  -->
    <!--         archiveFileName="C:\GitDev\BruTrader20\src\logs\ArchivedLogs\Archive_${shortdate}.{##}.log" archiveNumbering="DateAndSequence" archiveEvery="Day" maxArchiveFiles="30"  -->
    <!--         createDirs="true"/> -->

    <target name="CsvLog"
            xsi:type="File"
            fileName="C:\GitDev\BruTrader20\src\logs\BruTrader20.csvLog"
            archiveFileName="C:\GitDev\BruTrader20\src\logs\Archives/log_{#}_${date:format=yyyy-MM-d_HH}.csvLog"
            archiveEvery="Hour"
            archiveNumbering="Sequence"
            maxArchiveFiles="30000"
            concurrentWrites="true"
            keepFileOpen="false"
    >
      <layout xsi:type="CSVLayout">
        <withHeader>false</withHeader>
        <quoting>All</quoting>
        <column name ="sequence" layout ="${counter}" />
        <column name="time" layout="${date:format=yyyy/MM/dd HH\:mm\:ss.fff}" />
        <column name="level" layout="${level}"/>
        <column name="thread" layout="${threadid}"/>
        <column name="message" layout="${message}" />
        <column name="classname" layout ="${callsite:className=true:includeNamespace=true:fileName=false:includeSourcePath=false:methodName=false}" />
        <column name="method" layout ="${callsite:className=false:methodName=true:fileName=true:includeSourcePath=false}" />
        <column name="file" layout ="${callsite:className=false:methodName=false:fileName=true:includeSourcePath=false}" />
        <column name="exception" layout="${exception:format=Message,Type,StackTrace}" />
      </layout>
    </target>
    
    <!-- <target name="xmlFile" xsi:type="File" fileName="C:\GitDev\BruTrader20\src\logs\BruTrader20.xml" > -->
    <!--   layout="${log4jxmlevent:includeSourceInfo=true:includeCallSite=true:includeMDC=true:appInfo=true:includeNDC=true:includeNLogData=true}" -->
    <!-- </target> -->
    <!-- <target name="xmlFile" xsi:type="File" fileName="C:\GitDev\BruTrader20\src\logs\BruTrader20.xml" > -->
	   <!--  layout="${log4jxmlevent:includeSourceInfo=true:includeCallSite=true:includeMDC=true:includeNdc=true:includeNLogData=true}"/> -->
    <!-- </target> -->
    
    <!--<target name="xmlFile" xsi:type="File" fileName="C:\GitDev\BruTrader20\src\logs\BruTrader20.xml" >
      <layout xsi:type="XmlLayout" includeAllProperties="false" elementName='logevent'>
        <attribute name="time" layout="${longdate}" />
        <attribute name="level" layout="${level:upperCase=true}"/>
        <element name="message" value="${message}" />
      </layout>
    </target>-->
    <!-- <target name="xmlFile" xsi:type="File" fileName="C:\GitDev\BruTrader20\src\logs\BruTrader20.xml" > -->
    <!--   <layout type='XmlLayout' > -->
    <!--     <attribute name='logger' layout='${logger}' includeEmptyValue='true' /> -->
    <!--     <attribute name='level' layout='${uppercase:${level}}' includeEmptyValue='true' /> -->
    <!--     <element name='message' value='${message}' /> -->
    <!--     <element name='exception' value='${exception:format=message}' /> -->
    <!--     <element name='location'> -->
    <!--       <attribute name='class-name' layout='${callsite:methodName=false}' includeEmptyValue='true' /> -->
    <!--     </element> -->
    <!--   </layout> -->
    <!-- </target> -->
    
    <!--<target name="console" xsi:type="Console" layout="${message}${newline}${exception:format=ToString}"/>-->
    <!-- <target xsi:type="ColoredConsole" name="console" layout="${longdate} ${logger} ${uppercase:${level}} ${message}"/> -->
  </targets>

  
  <rules>
    <!--<logger name="*" minlevel="Trace" writeTo="log4viewCharts" />-->
     <logger name="*" minlevel="Trace" writeTo="log4viewDev"/> 
    <logger name="*" minlevel="Info" writeTo="log4viewTrading"/>
    <!--<logger name="*" minlevel="Trace" writeTo="console"/>-->
    <logger name="*" writeTo="CsvLog" minlevel="Debug"/>
    <!-- <logger name="*" writeTo="xmlFile" minlevel="Debug"/> -->
  </rules>
</nlog>
