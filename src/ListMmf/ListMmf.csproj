<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFrameworks>netcoreapp3.1;net46</TargetFrameworks>
    <Company>BruSoftware, LLC</Company>
    <Description>Array&lt;T&gt; on Memory Mapped Files</Description>
    <Copyright>Dale A. Brubaker</Copyright>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <RepositoryUrl>https://github.com/dalebrubaker/ArrayMmf</RepositoryUrl>
    <ApplicationIcon />
    <StartupObject />
    <AssemblyName>ListMmf</AssemblyName>
    <RootNamespace>BruSoftware.ListMmf</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\LICENSE.txt">
      <Pack>True</Pack>
      <PackagePath></PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.IO.FileSystem.AccessControl" Version="4.7.0" />
  </ItemGroup>

</Project>
